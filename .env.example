# ===========================================
# PetroChat — Variables de Entorno
# ===========================================
# Copiá este archivo como .env y completá los valores

# --- Groq (LLM) ---
GROQ_API_KEY=tu_clave_groq_aqui

# --- Pinecone (Base de datos vectorial) ---
PINECONE_API_KEY=tu_clave_pinecone_aqui
PINECONE_INDEX_NAME=petrochat

# --- Supabase ---
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu_clave_anon_aqui
SUPABASE_JWT_SECRET=tu_secreto_jwt_aqui

# --- Frontend (para el backend CORS) ---
FRONTEND_URL=http://localhost:5173

# --- Frontend (.env en /frontend) ---
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_clave_anon_aqui
VITE_API_URL=http://localhost:8000
