{
    "experimentalServices": {
        "frontend": {
            "entrypoint": "frontend",
            "routePrefix": "/",
            "framework": "vite"
        },
        "backend": {
            "entrypoint": "backend",
            "routePrefix": "/_/backend"
        }
    },
    "rewrites": [
        { "source": "/_/backend/(.*)", "destination": "/_/backend/$1" },
        { "source": "/((?!api|/_/backend).*)", "destination": "/index.html" }
    ]
}
